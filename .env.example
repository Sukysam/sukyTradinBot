# Foundation environment variables (Milestone 1).
#
# Copy this file to `.env` for local development: `cp .env.example .env`.
# `.env` is gitignored and must never be committed — see
# docs/engineering-handbook/Standards/Coding Standards.md's "Security &
# secrets" section.
#
# This file intentionally contains no trading-related variables
# (ALPACA_API_KEY, ALPACA_SECRET_KEY, ALPACA_PAPER, REGIME_TRADER_TICKERS —
# see docs/engineering-handbook/12_DEVOPS_ENGINEER.md for those). Those
# belong to regime-trader/, which this milestone does not touch.

# One of: development, test, production. Never defaults to production —
# see common.config.Settings.
ENVIRONMENT=development

# Standard Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# One of: json (structured, for log aggregation), console (human-readable,
# for local development).
LOG_FORMAT=console

APP_NAME=regime-trader
