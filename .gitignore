# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Environment / secrets — never commit real .env files
.env
.env.*
!.env.example

# Local, non-example configuration
config/*.yaml
config/*.yml
!config/*.example.yaml
!config/*.example.yml
# Generated but checked-in: regenerate via features.manifest.write_manifest
# and commit alongside any feature change (see manifest.py's docstring).
!config/feature_manifest.yaml

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Docker
*.pid
